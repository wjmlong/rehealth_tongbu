@Composable
private fun DeviceFeaturesContent() {
    Column(verticalArrangement = Arrangement.spacedBy(12.dp)) {
        CardBlock {
            SettingHeader(Icons.Outlined.Search, "找戒指")
            Text(
                "戒指将震动并亮起指示灯，帮助你快速找到",
                color = Muted,
                fontSize = 11.sp,
                modifier = Modifier.padding(top = 4.dp)
            )
            Button(
                onClick = { /* TODO: 发送findDevice命令 */ },
                modifier = Modifier.fillMaxWidth().padding(top = 12.dp),
                shape = RoundedCornerShape(14.dp),
                colors = ButtonDefaults.buttonColors(containerColor = Mint)
            ) {
                Icon(Icons.Outlined.NotificationsActive, null, modifier = Modifier.size(18.dp))
                Spacer(Modifier.width(8.dp))
                Text("开始寻找")
            }
        }

        CardBlock {
            SettingHeader(Icons.Outlined.WbTwilight, "抬腕亮屏")
            SwitchRow("开启抬腕亮屏", true) {}
            Text(
                "抬手时屏幕自动点亮",
                color = Muted,
                fontSize = 10.sp,
                modifier = Modifier.padding(top = 8.dp)
            )
        }

        CardBlock {
            SettingHeader(Icons.Outlined.LightMode, "屏幕亮度")
            SettingRow("亮屏时长", "30 秒")
            Slider(
                value = 0.7f,
                onValueChange = {},
                modifier = Modifier.fillMaxWidth().padding(top = 8.dp),
                colors = SliderDefaults.colors(
                    thumbColor = Mint,
                    activeTrackColor = Mint,
                    inactiveTrackColor = MintSoft
                )
            )
            Text("亮度 70%", color = Muted, fontSize = 10.sp, modifier = Modifier.padding(top = 4.dp))
        }

        CardBlock {
            SettingHeader(Icons.Outlined.LocationOn, "防丢提醒")
            SwitchRow("开启防丢提醒", false) {}
            HorizontalDivider(color = Line, modifier = Modifier.padding(vertical = 8.dp))
            SettingRow("提醒距离", "10 米")
            Text(
                "当戒指与手机距离超过设定值时提醒",
                color = Muted,
                fontSize = 10.sp,
                modifier = Modifier.padding(top = 8.dp)
            )
        }

        CardBlock {
            SettingHeader(Icons.Outlined.CameraAlt, "遥控拍照")
            Text(
                "通过戒指按键触发手机拍照",
                color = Muted,
                fontSize = 11.sp,
                modifier = Modifier.padding(top = 4.dp)
            )
            SwitchRow("启用遥控拍照", false, Modifier.padding(top = 8.dp)) {}
        }
    }
}

@Composable
private fun SystemInfoContent() {
    Column(verticalArrangement = Arrangement.spacedBy(12.dp)) {
        CardBlock {
            SettingHeader(Icons.Outlined.Info, "设备信息")
            InfoRow("固件版本", "1.3.0")
            InfoRow("硬件版本", "MR11")
            InfoRow("蓝牙地址", "AA:BB:CC:DD:EE:FF")
            InfoRow("序列号", "MRD2026001234")
            Button(
                onClick = { /* TODO: 检查更新 */ },
                modifier = Modifier.fillMaxWidth().padding(top = 12.dp),
                shape = RoundedCornerShape(14.dp),
                colors = ButtonDefaults.buttonColors(containerColor = MintSoft, contentColor = Mint)
            ) {
                Text("检查固件更新")
            }
        }

        CardBlock {
            SettingHeader(Icons.Outlined.BatteryFull, "电池信息")
            Row(
                modifier = Modifier.fillMaxWidth().padding(vertical = 12.dp),
                verticalAlignment = Alignment.CenterVertically
            ) {
                Column(Modifier.weight(1f)) {
                    Text("当前电量", color = Muted, fontSize = 11.sp)
                    Row(verticalAlignment = Alignment.Bottom, modifier = Modifier.padding(top = 4.dp)) {
                        Text("85", color = Ink, fontSize = 36.sp, fontWeight = FontWeight.Bold)
                        Text("%", color = Muted, fontSize = 18.sp, modifier = Modifier.padding(bottom = 6.dp, start = 2.dp))
                    }
                    Text("预计可用 3 天", color = Mint, fontSize = 11.sp, modifier = Modifier.padding(top = 4.dp))
                </Column>
                Box(
                    modifier = Modifier
                        .size(80.dp)
                        .clip(CircleShape)
                        .background(MintSoft),
                    contentAlignment = Alignment.Center
                ) {
                    Icon(
                        Icons.Outlined.BatteryFull,
                        null,
                        tint = Mint,
                        modifier = Modifier.size(40.dp)
                    )
                }
            }
        }

        CardBlock {
            SettingHeader(Icons.Outlined.Storage, "存储信息")
            InfoRow("已用存储", "2.3 MB / 4.0 MB")
            LinearProgressIndicator(
                progress = { 0.58f },
                modifier = Modifier.fillMaxWidth().padding(vertical = 8.dp),
                color = Mint,
                trackColor = MintSoft
            )
            Button(
                onClick = { /* TODO: 清除数据 */ },
                modifier = Modifier.fillMaxWidth().padding(top = 8.dp),
                shape = RoundedCornerShape(14.dp),
                colors = ButtonDefaults.buttonColors(containerColor = Color(0xFFF1F4F3), contentColor = Ink)
            ) {
                Text("清除戒指数据")
            }
        }

        CardBlock {
            SettingHeader(Icons.Outlined.RestartAlt, "恢复出厂设置", Color(0xFFFF6078))
            Text(
                "此操作将清除戒指上的所有数据和设置，无法恢复",
                color = Muted,
                fontSize = 11.sp,
                modifier = Modifier.padding(top = 4.dp)
            )
            Button(
                onClick = { /* TODO: 确认对话框 */ },
                modifier = Modifier.fillMaxWidth().padding(top = 12.dp),
                shape = RoundedCornerShape(14.dp),
                colors = ButtonDefaults.buttonColors(containerColor = Color(0xFFFFEBEE), contentColor = Color(0xFFFF6078))
            ) {
                Text("恢复出厂设置")
            }
        }
    }
}

@Composable
private fun SettingHeader(icon: ImageVector, title: String, color: Color = Mint) {
    Row(verticalAlignment = Alignment.CenterVertically) {
        Icon(icon, null, tint = color, modifier = Modifier.size(22.dp))
        Text(
            title,
            color = Ink,
            fontSize = 15.sp,
            fontWeight = FontWeight.Bold,
            modifier = Modifier.padding(start = 8.dp)
        )
    }
}

@Composable
private fun SwitchRow(label: String, checked: Boolean, modifier: Modifier = Modifier, onCheckedChange: (Boolean) -> Unit) {
    Row(
        modifier = modifier.fillMaxWidth(),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Text(label, color = Ink, fontSize = 13.sp, modifier = Modifier.weight(1f))
        Switch(
            checked = checked,
            onCheckedChange = onCheckedChange,
            colors = SwitchDefaults.colors(
                checkedThumbColor = Color.White,
                checkedTrackColor = Mint,
                uncheckedThumbColor = Color.White,
                uncheckedTrackColor = Color(0xFFE0E0E0)
            )
        )
    }
}

@Composable
private fun SettingRow(label: String, value: String) {
    Row(
        modifier = Modifier
            .fillMaxWidth()
            .clickable { /* TODO */ }
            .padding(vertical = 8.dp),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Text(label, color = Ink, fontSize = 13.sp, modifier = Modifier.weight(1f))
        Text(value, color = Muted, fontSize = 12.sp)
        Icon(Icons.Outlined.ChevronRight, null, tint = Muted, modifier = Modifier.size(18.dp))
    }
}

@Composable
private fun InfoRow(label: String, value: String) {
    Row(
        modifier = Modifier.fillMaxWidth().padding(vertical = 8.dp),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Text(label, color = Muted, fontSize = 12.sp, modifier = Modifier.weight(1f))
        Text(value, color = Ink, fontSize = 12.sp, fontWeight = FontWeight.Medium)
    }
}
